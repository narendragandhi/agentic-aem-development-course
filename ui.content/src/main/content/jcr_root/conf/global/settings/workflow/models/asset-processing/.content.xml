<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:designPath="/libs/settings/wcm/designs/default"
        cq:template="/libs/cq/workflow/templates/model"
        jcr:primaryType="cq:WorkflowModel"
        jcr:title="Asset Processing Workflow"
        sling:resourceType="cq/workflow/components/pages/model"
        description="Comprehensive asset processing with parallel metadata extraction, rendition generation, and watermarking"
        tags="[workflow:dam]"
        title="Asset Processing Workflow">
        <flow jcr:primaryType="nt:unstructured">
            <node0
                jcr:primaryType="nt:unstructured"
                jcr:title="Start"
                sling:resourceType="cq/workflow/components/model/start"
                type="START">
                <metaData jcr:primaryType="nt:unstructured"/>
            </node0>
            <node1
                jcr:primaryType="nt:unstructured"
                jcr:title="Parallel Processing Start"
                sling:resourceType="cq/workflow/components/model/andsplit"
                description="Execute metadata extraction, rendition generation, and watermarking in parallel"
                type="AND_SPLIT">
                <metaData jcr:primaryType="nt:unstructured"/>
            </node1>
            <node2
                jcr:primaryType="nt:unstructured"
                jcr:title="Extract Metadata"
                sling:resourceType="cq/workflow/components/model/process"
                description="Extract and process metadata from asset"
                type="PROCESS">
                <metaData
                    jcr:primaryType="nt:unstructured"
                    PROCESS="com.demo.workflow.process.MetadataEnrichmentProcess"
                    PROCESS_AUTO_ADVANCE="true"/>
            </node2>
            <node3
                jcr:primaryType="nt:unstructured"
                jcr:title="Generate Renditions"
                sling:resourceType="cq/workflow/components/model/process"
                description="Generate required renditions for the asset"
                type="PROCESS">
                <metaData
                    jcr:primaryType="nt:unstructured"
                    PROCESS="com.day.cq.dam.core.process.CreateThumbnailProcess"
                    PROCESS_AUTO_ADVANCE="true"
                    CONFIGS="[140:100:false,48:48:false,319:319:false]"/>
            </node3>
            <node4
                jcr:primaryType="nt:unstructured"
                jcr:title="Apply Watermark"
                sling:resourceType="cq/workflow/components/model/process"
                description="Apply watermark to renditions for brand protection"
                type="PROCESS">
                <metaData
                    jcr:primaryType="nt:unstructured"
                    PROCESS="com.demo.workflow.process.WatermarkProcess"
                    PROCESS_AUTO_ADVANCE="true"
                    watermarkPath="/content/dam/demo-workflow/watermarks/company-logo.png"/>
            </node4>
            <node5
                jcr:primaryType="nt:unstructured"
                jcr:title="Parallel Processing Complete"
                sling:resourceType="cq/workflow/components/model/andjoin"
                description="Wait for all parallel processing to complete"
                type="AND_JOIN">
                <metaData jcr:primaryType="nt:unstructured"/>
            </node5>
            <node6
                jcr:primaryType="nt:unstructured"
                jcr:title="Smart Tag Analysis"
                sling:resourceType="cq/workflow/components/model/process"
                description="Apply AI-powered smart tagging to asset"
                type="PROCESS">
                <metaData
                    jcr:primaryType="nt:unstructured"
                    PROCESS="com.day.cq.dam.similaritysearch.internal.workflow.process.AutoTagAssetProcess"
                    PROCESS_AUTO_ADVANCE="true"/>
            </node6>
            <node7
                jcr:primaryType="nt:unstructured"
                jcr:title="Sync Tags to XMP"
                sling:resourceType="cq/workflow/components/model/process"
                description="Synchronize smart tags to XMP metadata"
                type="PROCESS">
                <metaData
                    jcr:primaryType="nt:unstructured"
                    PROCESS="com.demo.workflow.process.SyncTagsToXmpProcess"
                    PROCESS_AUTO_ADVANCE="true"/>
            </node7>
            <node8
                jcr:primaryType="nt:unstructured"
                jcr:title="Set Image Orientation"
                sling:resourceType="cq/workflow/components/model/process"
                description="Automatically set image orientation tags based on aspect ratio"
                type="PROCESS">
                <metaData
                    jcr:primaryType="nt:unstructured"
                    PROCESS="com.demo.workflow.process.SetImageOrientationProcess"
                    PROCESS_AUTO_ADVANCE="true"/>
            </node8>
            <node9
                jcr:primaryType="nt:unstructured"
                jcr:title="Brand Portal Sync Check"
                sling:resourceType="cq/workflow/components/model/orsplit"
                description="Check if asset should be synced to Brand Portal"
                type="OR_SPLIT">
                <metaData jcr:primaryType="nt:unstructured">
                    <branches jcr:primaryType="nt:unstructured">
                        <branch0
                            jcr:primaryType="nt:unstructured"
                            condition="function check() { var path = workflowData.getPayload().toString(); return path.indexOf('/approved/') > -1; }"/>
                        <branch1
                            jcr:primaryType="nt:unstructured"
                            condition="function check() { return true; }"/>
                    </branches>
                </metaData>
            </node9>
            <node10
                jcr:primaryType="nt:unstructured"
                jcr:title="Sync to Brand Portal"
                sling:resourceType="cq/workflow/components/model/process"
                description="Synchronize approved asset to Brand Portal"
                type="PROCESS">
                <metaData
                    jcr:primaryType="nt:unstructured"
                    PROCESS="com.demo.workflow.process.BrandPortalSyncProcess"
                    PROCESS_AUTO_ADVANCE="true"/>
            </node10>
            <node11
                jcr:primaryType="nt:unstructured"
                jcr:title="Notify Asset Owners"
                sling:resourceType="cq/workflow/components/model/process"
                description="Send notification to asset owners about processing completion"
                type="PROCESS">
                <metaData
                    jcr:primaryType="nt:unstructured"
                    PROCESS="com.demo.workflow.process.NotificationProcess"
                    PROCESS_AUTO_ADVANCE="true"
                    notificationType="asset_processed"/>
            </node11>
            <node12
                jcr:primaryType="nt:unstructured"
                jcr:title="Update Replication Status"
                sling:resourceType="cq/workflow/components/model/process"
                description="Update replication status metadata"
                type="PROCESS">
                <metaData
                    jcr:primaryType="nt:unstructured"
                    PROCESS="com.demo.workflow.process.SetReplicationStatusProcess"
                    PROCESS_AUTO_ADVANCE="true"/>
            </node12>
            <node13
                jcr:primaryType="nt:unstructured"
                jcr:title="End"
                sling:resourceType="cq/workflow/components/model/end"
                type="END">
                <metaData jcr:primaryType="nt:unstructured"/>
            </node13>
            <transitions jcr:primaryType="nt:unstructured">
                <transition0 jcr:primaryType="nt:unstructured" from="node0" to="node1"/>
                <transition1 jcr:primaryType="nt:unstructured" from="node1" to="node2"/>
                <transition2 jcr:primaryType="nt:unstructured" from="node1" to="node3"/>
                <transition3 jcr:primaryType="nt:unstructured" from="node1" to="node4"/>
                <transition4 jcr:primaryType="nt:unstructured" from="node2" to="node5"/>
                <transition5 jcr:primaryType="nt:unstructured" from="node3" to="node5"/>
                <transition6 jcr:primaryType="nt:unstructured" from="node4" to="node5"/>
                <transition7 jcr:primaryType="nt:unstructured" from="node5" to="node6"/>
                <transition8 jcr:primaryType="nt:unstructured" from="node6" to="node7"/>
                <transition9 jcr:primaryType="nt:unstructured" from="node7" to="node8"/>
                <transition10 jcr:primaryType="nt:unstructured" from="node8" to="node9"/>
                <transition11 jcr:primaryType="nt:unstructured" from="node9" to="node10" rule="branch0"/>
                <transition12 jcr:primaryType="nt:unstructured" from="node9" to="node11" rule="branch1"/>
                <transition13 jcr:primaryType="nt:unstructured" from="node10" to="node11"/>
                <transition14 jcr:primaryType="nt:unstructured" from="node11" to="node12"/>
                <transition15 jcr:primaryType="nt:unstructured" from="node12" to="node13"/>
            </transitions>
        </flow>
    </jcr:content>
</jcr:root>
